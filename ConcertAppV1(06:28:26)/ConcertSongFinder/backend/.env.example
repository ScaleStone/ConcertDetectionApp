# Copy to .env for local development. On cloud hosts (Render/Railway),
# set these as environment variables in the dashboard instead.

# Required: setlist.fm API key (https://api.setlist.fm)
SETLIST_FM_API_KEY=

# Required: shared token the iOS app sends as X-API-Key.
# Must match CSFBackendAPIKey in the app's Info.plist.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
BACKEND_API_KEY=

# Optional: licensed lyrics provider (placeholder until configured)
LYRICS_PROVIDER_API_KEY=
LYRICS_PROVIDER_BASE_URL=

CACHE_TTL_SECONDS=900
ALLOWED_ORIGINS=http://localhost:3000
